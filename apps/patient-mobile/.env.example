# Patienten-App – lokale Entwicklung gegen die lokale Supabase-Instanz.
# Kopieren nach .env (wird nicht committet). NIEMALS einen service_role-
# Schlüssel eintragen – die App nutzt ausschließlich den Publishable Key.

# Werte aus `supabase status` (API_URL und PUBLISHABLE_KEY).
# Im iOS-Simulator funktioniert 127.0.0.1; auf einem echten Gerät die
# LAN-IP des Macs eintragen (z. B. http://192.168.x.y:54321).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...

# Next.js-Server der Website (liefert die wenigen /api/mobile-Endpunkte).
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
