{
  "name": "physio-check",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23.0.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:rls": "node --env-file=.env.local --import tsx scripts/rls-tests.ts",
    "seed": "node --env-file=.env.local --import tsx scripts/seed.ts",
    "docs:sync": "node --env-file=.env.local --import tsx scripts/sync-obsidian.ts",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/server/db/database.types.ts",
    "mobile:start": "pnpm --dir apps/patient-mobile start",
    "mobile:ios": "pnpm --dir apps/patient-mobile ios",
    "mobile:android": "pnpm --dir apps/patient-mobile android",
    "mobile:typecheck": "pnpm --dir apps/patient-mobile typecheck",
    "mobile:lint": "pnpm --dir apps/patient-mobile lint",
    "mobile:test": "pnpm --dir apps/patient-mobile test",
    "shared:typecheck": "pnpm --dir packages/shared typecheck"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "@physio-check/shared": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
