# Öffentliche lokale Supabase-Verbindung (`supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_LOCAL_ANON_KEY_HERE

# Ausschließlich serverseitig. Niemals mit NEXT_PUBLIC_ prefixen.
SUPABASE_SERVICE_ROLE_KEY=PASTE_LOCAL_SERVICE_ROLE_KEY_HERE

# Basis für Bestätigungs- und Einladungslinks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Obsidian-Vault für `pnpm docs:sync` (optional; nur Projektdoku, nie Patientendaten)
OBSIDIAN_VAULT_PATH=/PFAD/ZU/DEINEM/VAULT

# Malware-Scan für Profilbild-/Übungsmedien-Uploads (ClamAV `clamscan`
# muss lokal installiert sein). Standard: aus (lokale Entwicklung und
# CI-Standardlauf haben keinen persistenten Scanner). Siehe
# docs/PRIVACY_SECURITY.md und docs/RELEASE_READINESS.md (Bereich A4).
MALWARE_SCAN_ENABLED=false
